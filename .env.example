# ─────────────────────────────────────────────────────────────────────────────
# Enterprise AI Chatbot — Environment Variables Reference
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
#
# Quickest start: run `bash scripts/setup.sh` — it generates this file
# with secure random secrets automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
# Local GitHub/download setup should use "development" so demo seeding works.
# MUST be changed to "production" for any internet-facing deployment.
# Controls JWT cookie Secure flag, Swagger UI visibility, and other guards.
ENVIRONMENT=development
PROJECT_NAME=Enterprise AI Chatbot

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-a-long-random-secret-min-32-chars
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=replace-with-32-byte-base64-encoded-key
ALLOW_DEV_AUTH_BYPASS=false      # NEVER set true in staging or production
ACCESS_TOKEN_EXPIRE_MINUTES=60   # default 1h; production max is 120
REFRESH_TOKEN_EXPIRE_DAYS=7      # rotating httpOnly refresh-token cookie lifetime

# ── First-run admin bootstrap ─────────────────────────────────────────────────
# Optional: auto-create the first admin account on startup if the database is empty.
# For the easiest local demo, leave these blank and run `make seed` or the
# equivalent Docker command so random demo credentials are printed clearly.
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=

# ── Database — PostgreSQL + pgvector ─────────────────────────────────────────
# For Docker Compose: POSTGRES_* vars are used by the postgres container.
# DATABASE_URL for Docker uses host "db" (the compose service name).
# DATABASE_URL for local dev (no Docker) uses "localhost".
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=aiagent_db
# Docker Compose: change "localhost" to "db"
DATABASE_URL=postgresql://postgres:replace-with-strong-password@localhost:5432/aiagent_db
# For Neon / hosted Postgres:
# DATABASE_URL=postgresql://user:password@host.neon.tech:5432/dbname?sslmode=require

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
REDIS_PASSWORD=replace-with-a-long-random-redis-password
REDIS_URL=redis://:replace-with-a-long-random-redis-password@localhost:6379/0

# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
ENABLE_HSTS=false
# Trusted reverse proxy IPs/CIDRs (default covers loopback + Docker bridge)
TRUSTED_PROXY_CIDRS=127.0.0.1,::1,172.16.0.0/12

# ── Document storage ──────────────────────────────────────────────────────────
DOCUMENT_STORAGE_DIR=./storage/documents

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production, restrict to your actual domain.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Demo Seed Passwords (optional) ────────────────────────────────────────────
# By default, seed_demo.py generates random passwords for security.
# Set these to use fixed passwords in development:
# SEED_ADMIN_PASSWORD=admin1234
# SEED_ALICE_PASSWORD=alice1234

# ── LLM — per-user API keys (managed via User Settings → Models) ─────────────
# API keys are stored encrypted in the database, not here.
# Add keys after login: User Settings → Models → Add Model.

# ── Web Search (optional) ─────────────────────────────────────────────────────
GOOGLE_SEARCH_API_KEY=your_google_api_key
GOOGLE_SEARCH_CX=your_google_programmable_search_cx
BING_SEARCH_API_KEY=your_bing_search_api_key
CUSTOM_ENDPOINT_ALLOWLIST=

# ── RAG tuning ────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATES_K=10
FINAL_CONTEXT_K=3
MAX_CONTEXT_CHARS=8000
CACHE_SIMILARITY_THRESHOLD=0.10
MIN_RERANK_SCORE=0.05
MAX_HISTORY_MESSAGES=10

# ── Cost tracking ─────────────────────────────────────────────────────────────
LOCAL_COST_BUDGET=10.0
