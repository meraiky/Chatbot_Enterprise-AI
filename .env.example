# ─────────────────────────────────────────────────────────────────────────────
# Enterprise AI Chatbot — Environment Variables Reference
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
PROJECT_NAME=Enterprise AI Chatbot

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-long-random-secret-min-32-chars
ENCRYPTION_KEY=replace-with-32-byte-base64-encoded-key
ALLOW_DEV_AUTH_BYPASS=false      # NEVER set true in staging or production
ACCESS_TOKEN_EXPIRE_MINUTES=120  # default 2h; reduce further for high-security envs

# ── Database — PostgreSQL + pgvector ─────────────────────────────────────────
# For Docker Compose: POSTGRES_* vars set the DB container credentials.
# Change POSTGRES_PASSWORD in production — never leave it as the default.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=aiagent_db
DATABASE_URL=postgresql://postgres:replace-with-strong-password@localhost:5432/aiagent_db
# For Neon / hosted Postgres:
# DATABASE_URL=postgresql://user:password@host.neon.tech:5432/dbname?sslmode=require

# ── Redis (optional — production caching) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=replace-with-a-long-random-redis-password
APP_HOST=127.0.0.1
APP_PORT=8000
ENABLE_HSTS=false

# ── Document storage ──────────────────────────────────────────────────────────
DOCUMENT_STORAGE_DIR=./storage/documents

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8501

# ── Demo Seed Passwords (optional) ────────────────────────────────────────────
# By default, seed_demo.py generates random passwords for security.
# Set these to use fixed passwords in development:
# SEED_ADMIN_PASSWORD=admin1234
# SEED_ALICE_PASSWORD=alice1234

# ── LLM — managed via Admin Dashboard API Key Pool ───────────────────────────
# API keys are stored encrypted in the database, not here.
# Add keys through the Admin UI at /admin after first login.

# ── Web Search (optional) ─────────────────────────────────────────────────────
GOOGLE_SEARCH_API_KEY=your_google_api_key
GOOGLE_SEARCH_CX=your_google_programmable_search_cx
BING_SEARCH_API_KEY=your_bing_search_api_key

# ── RAG tuning ────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATES_K=10
FINAL_CONTEXT_K=3
MAX_CONTEXT_CHARS=8000
CACHE_SIMILARITY_THRESHOLD=0.10
MIN_RERANK_SCORE=0.05
MAX_HISTORY_MESSAGES=10

# ── Cost tracking ─────────────────────────────────────────────────────────────
LOCAL_COST_BUDGET=10.0

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Prefix with VITE_ to expose to the browser bundle
VITE_API_URL=http://localhost:8000
REQUEST_TIMEOUT=60

# ── Streamlit client ──────────────────────────────────────────────────────────
API_URL=http://localhost:8000
