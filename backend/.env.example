# ── Deployment environment ────────────────────────────────────────────────────
# Local GitHub/download setup should use "development" so demo seeding works.
# MUST be set to "production" for internet-facing deployments.
# Controls JWT cookie Secure flag and other security settings.
ENVIRONMENT=development

# ── LLM API Keys ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_key_here
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-32-byte-base64-key
ALLOW_DEV_AUTH_BYPASS=false
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── First-run admin bootstrap ─────────────────────────────────────────────────
# Set these once to auto-create the first admin account on startup.
# After the account is created, you can remove or leave them — they're ignored
# once any user exists in the database.
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=

# ── PostgreSQL (required) ─────────────────────────────────────────────────────
# For docker-compose deployments, set all four variables.
# For Railway/Render/Supabase, only DATABASE_URL is needed.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=aiagent_db
DATABASE_URL=postgresql://postgres:replace-with-strong-password@localhost:5432/aiagent_db

# ── Redis (required for production rate limiting) ─────────────────────────────
REDIS_PASSWORD=replace-with-a-long-random-redis-password
REDIS_URL=redis://:replace-with-a-long-random-redis-password@localhost:6379/0

# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
ENABLE_HSTS=false
# Comma-separated trusted reverse proxy IPs/CIDRs (default covers loopback + Docker bridge)
TRUSTED_PROXY_CIDRS=127.0.0.1,::1,172.16.0.0/12

# ── Models ────────────────────────────────────────────────────────────────────
CHAT_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# ── Storage ───────────────────────────────────────────────────────────────────
DOCUMENT_STORAGE_DIR=./storage/documents

# ── CORS ──────────────────────────────────────────────────────────────────────
# In Docker / production behind nginx, only the nginx-served frontend URL is needed.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── RAG tuning ────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATES_K=10
FINAL_CONTEXT_K=3
MAX_CONTEXT_CHARS=8000
CACHE_SIMILARITY_THRESHOLD=0.10
MIN_RERANK_SCORE=0.05
MAX_HISTORY_MESSAGES=10
TOKEN_USAGE_DB=./token_usage.db

# ── Web Search API Keys (Optional) ───────────────────────────────────────────
GOOGLE_SEARCH_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_CX=your_google_cx_id_here
BING_SEARCH_API_KEY=your_bing_api_key_here
CUSTOM_ENDPOINT_ALLOWLIST=

# ── Demo Seed Passwords (optional) ────────────────────────────────────────────
# By default, seed_demo.py generates random passwords for security.
# Set these to use fixed passwords in development:
# SEED_ADMIN_PASSWORD=admin1234
# SEED_ALICE_PASSWORD=alice1234
