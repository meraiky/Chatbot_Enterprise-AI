GEMINI_API_KEY=your_key_here
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
JWT_SECRET_KEY=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-32-byte-base64-key
ALLOW_DEV_AUTH_BYPASS=false
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aiagent_db
REDIS_PASSWORD=replace-with-a-long-random-redis-password
REDIS_URL=redis://:replace-with-a-long-random-redis-password@localhost:6379/0
APP_HOST=127.0.0.1
APP_PORT=8000
ENABLE_HSTS=false
CHAT_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
CHROMA_PERSIST_DIRECTORY=./chroma_db
DOCUMENT_STORAGE_DIR=./storage/documents
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8501,http://127.0.0.1:8501

# ── Demo Seed Passwords (optional) ────────────────────────────────────────────
# By default, seed_demo.py generates random passwords for security.
# Set these to use fixed passwords in development:
# SEED_ADMIN_PASSWORD=admin1234
# SEED_ALICE_PASSWORD=alice1234
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATES_K=10
FINAL_CONTEXT_K=3
MAX_CONTEXT_CHARS=8000
CACHE_SIMILARITY_THRESHOLD=0.10
MIN_RERANK_SCORE=0.05
MAX_HISTORY_MESSAGES=10
TOKEN_USAGE_DB=./token_usage.db

# Web Search API Keys (Optional)
GOOGLE_SEARCH_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_CX=your_google_cx_id_here
BING_SEARCH_API_KEY=your_bing_api_key_here
CUSTOM_ENDPOINT_ALLOWLIST=
